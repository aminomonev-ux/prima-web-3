# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Local archive (file sementara, tidak perlu di-track)
/_archive

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code local config — ignore by default, EXCEPT shared governance files
.claude/*
!.claude/settings.json
!.claude/skills/
.claude/skills/*
!.claude/skills/audit-check/
!.claude/rules/
.claude/rules/*
!.claude/rules/*.md
# (worktrees, settings.local.json, launch.json tetap ignored)
.claude/worktrees/
.claude/settings.local.json
.claude/launch.json

# AI tools config (tidak perlu di-track)
.cursorrules
AGENTS.md
LEAN-CTX.md
prima-web.rar
docs/flowchart-usulan.html

# graphify temp files
.graphify_*.json
.graphify_*.txt
.graphify_python

# graphify caches (auto-regenerable, large) — outputs (GRAPH_REPORT.md, graph.json, graph.html, manifest.json, cost.json) tetap di-track
graphify-out/cache/
graphify-out/converted/
graphify-out/.graphify_chunk_*.json
graphify-out/.needs_update
# stray graphify-out dir yang kadang dibuat extract() di subfolder app/ (bukan root)
/app/**/graphify-out/

# lean-ctx cache files
*.lean-ctx
.lean-ctx/

# backup DB (scripts/backup-db.js) - jangan commit dump/log
backups-pending/
scripts/backup-db.log
