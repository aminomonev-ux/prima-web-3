# PRIMA — Environment Template (INTRANET EDITION / LAN-only)
# Salin file ini menjadi `.env.local` lalu isi nilai sebenarnya.
# JANGAN commit `.env.local` ke git (sudah ada di .gitignore).
#
# Branch aktif: mysql. Edisi intranet: email & Turnstile DIMATIKAN (lihat docs/INTRANET-DELTA.md).

# ─── MySQL (WAJIB) ────────────────────────────────────────────────
MYSQL_HOST="localhost"
MYSQL_PORT="3306"
MYSQL_USER="prima_user"
MYSQL_PASSWORD="<set-strong-password>"
MYSQL_DATABASE="prima_db"
MYSQL_SSL="false"

# ─── JWT / Session (WAJIB) ────────────────────────────────────────
# Generate: `node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"`
# Minimal 32 chars — kalau pendek/kosong, app throw fatal saat startup (SEC-C1).
JWT_SECRET="<generate-min-32-chars>"

# ─── Rate-limit (Redis lokal — REKOMENDASI server kantor) ─────────
# Auto-detect di ratelimit.ts: REDIS_URL terisi → Redis lokal (lintas-proses, akurat).
# Kosong → fallback throttle in-memory per-proses (V5-AUTH-04), BUKAN fail-open —
# throttle minimal tetap jalan. Isi REDIS_URL untuk rate-limit produksi yang benar.
# Upstash cloud TIDAK dipakai di edisi intranet.
REDIS_URL="redis://127.0.0.1:6379"

# ─── Google Drive (OPSIONAL — butuh internet OUTBOUND dari server) ─
# Lampiran Usulan + arsip docx LKJIP. Kosongkan semua untuk menonaktifkan.
GOOGLE_DRIVE_FOLDER_ID="<folder-id>"
GOOGLE_OAUTH_CLIENT_ID="<xxx.apps.googleusercontent.com>"
GOOGLE_OAUTH_CLIENT_SECRET="<client-secret>"
GOOGLE_OAUTH_REFRESH_TOKEN="<refresh-token>"
GOOGLE_DRIVE_FOLDER_ID_LKJIP="<folder-id-lkjip>"

# ─── Cron Jobs (WAJIB untuk endpoint /api/cron/*) ─────────────────
# Generate: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
# Dipakai header `Authorization: Bearer ${CRON_SECRET}` (purge-retention, promotion-*).
CRON_SECRET="<generate-min-32-chars>"

# ─── Role Promotion Ladder (WAJIB untuk modul Promotion) ──────────
# PROMOTION_SECRET — user input saat klik "Upgrade Role" (L2). Format memorable 12-16 char.
PROMOTION_SECRET="Prima-XXXX-2026"
# RECOVERY_SECRET — emergency all-SA-locked (single-use, via SQL/admin tool). `openssl rand -hex 16`.
PROMOTION_RECOVERY_SECRET="<generate-32-char-hex>"
# Comma-separated email owner (max 3) — penerima alert bootstrap & emergency.
PROMOTION_OWNER_EMAILS="owner@example.com"

# ─── App ──────────────────────────────────────────────────────────
# Hostname LAN internal (bukan IP mentah) — link/redirect resolve di jaringan kantor.
NEXT_PUBLIC_APP_URL="http://prima.kantor.local"
NODE_ENV="development"
# ─── Cookie Secure flag ───────────────────────────────────────────
# Default: ON saat NODE_ENV=production (butuh HTTPS).
# Set "false" utk intranet HTTP (cookie session tidak ditolak browser).
# JANGAN set "false" kalau server diakses dari luar LAN.
COOKIE_SECURE="false"

# ─── DIHAPUS dari edisi intranet ──────────────────────────────────
# GMAIL_USER, GMAIL_APP_PASSWORD, NEXT_PUBLIC_GMAIL_USER, SENDGRID_API_KEY
# NEXT_PUBLIC_TURNSTILE_SITE_KEY, TURNSTILE_SECRET_KEY, TURNSTILE_FAILOPEN
# UPSTASH_REDIS_REST_URL, UPSTASH_REDIS_REST_TOKEN
