#!/usr/bin/env bash
# PRIMA secret-scan pre-commit — tolak commit yang mengandung secret (push-protection lokal).
# Pakai .gitleaks.toml yang sama dengan CI gate D. Fail-open kalau gitleaks belum ada,
# fail-closed kalau secret terdeteksi. Set core.hooksPath=.githooks untuk mengaktifkan.

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "⚠️  gitleaks belum terinstall — secret-scan lokal DILEWATI."
  echo "    Install: winget install gitleaks  (atau scoop install gitleaks)"
  echo "    CI gate D tetap memindai saat push. Lanjut commit..."
  exit 0
fi

gitleaks protect --staged --redact --config .gitleaks.toml --verbose
status=$?

if [ $status -ne 0 ]; then
  echo ""
  echo "❌ Secret terdeteksi di staged changes — commit DIBATALKAN."
  echo "   Hapus/rotasi secret di atas, lalu commit ulang."
  echo "   (false positive? tambahkan ke allowlist .gitleaks.toml)"
  exit 1
fi

exit 0
